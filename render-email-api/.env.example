PORT=5000
REQUIRE_FIREBASE_AUTH=true
ALLOWED_ORIGINS=https://cmbankrsa.com,https://www.cmbankrsa.com,http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000,http://localhost:63342,http://127.0.0.1:63342,https://your-static-app-domain.com

# Required: SendGrid API key with Mail Send permission
SENDGRID_API_KEY=SG.xxxxx

# Required: Verified sender in SendGrid
SENDGRID_FROM_EMAIL=alert@cmbankrsa.com

# Required when deploying on Render unless using GOOGLE_APPLICATION_CREDENTIALS
# Paste minified JSON as single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"rsa-doc-app"}

# Optional: EmailJS settings for scheduled report sending
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY
EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID
EMAILJS_REPORT_TEMPLATE_ID=YOUR_EMAILJS_REPORT_TEMPLATE_ID

# Optional but recommended for server-side EmailJS REST calls
EMAILJS_PRIVATE_KEY=YOUR_EMAILJS_PRIVATE_KEY

# Your EmailJS template should define a Variable Attachment using this parameter name
EMAILJS_ATTACHMENT_PARAM=report_attachment
EMAILJS_ATTACHMENT_FILENAME_PARAM=report_attachment_filename

# Leave true to allow the backend to check every 30 seconds for due scheduled reports
ENABLE_SCHEDULED_REPORT_SENDER=true

# Optional: enables bank account name lookup in the submission form
PAYSTACK_SECRET_KEY=sk_live_or_test_xxxxx

# Optional: max JSON payload accepted by the server-side PDF converter
PDF_RENDER_BODY_LIMIT=24mb

# Optional: set this only if LibreOffice is installed outside PATH
# LIBREOFFICE_PATH=/usr/bin/soffice

# Render deploy note:
# Keep render-email-api/Aptfile with LibreOffice packages enabled for DOCX-to-PDF conversion.
