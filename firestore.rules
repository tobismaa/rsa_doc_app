rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userDocPath());
    }

    function myEmail() {
      return signedIn() ? request.auth.token.email : '';
    }

    function userRole() {
      return hasUserProfile() ? get(userDocPath()).data.role : '';
    }

    function isRole(role) {
      return userRole() == role;
    }

    function isAnyRole(roles) {
      return userRole() in roles;
    }

    function isAdminLike() {
      return isAnyRole(['admin', 'super_admin']);
    }

    function canMonitorAll() {
      return isAnyRole(['admin', 'super_admin', 'reports_monitoring']);
    }

    function systemSettingsPath() {
      return /databases/$(database)/documents/settings/system;
    }

    function maintenanceModeEnabled() {
      return exists(systemSettingsPath()) && get(systemSettingsPath()).data.maintenanceMode == true;
    }

    function readOnlyModeEnabled() {
      return exists(systemSettingsPath()) && get(systemSettingsPath()).data.globalReadOnlyMode == true;
    }

    function maintenanceWriteAllowed() {
      return !maintenanceModeEnabled() || isRole('super_admin');
    }

    function globalWriteAllowed() {
      return ((!maintenanceModeEnabled() && !readOnlyModeEnabled()) || isRole('super_admin'));
    }

    function isOwnUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function uniqueKeyPath(keyId) {
      return /databases/$(database)/documents/userUniqueKeys/$(keyId);
    }

    function emailKeyId(email) {
      return 'email:' + email;
    }

    function whatsappKeyId(number) {
      return 'whatsapp:' + number;
    }

    function hasMatchingUniqueKeyAfter(type, value, userId) {
      return !(value is string) || value == '' || (
        existsAfter(uniqueKeyPath(type == 'email' ? emailKeyId(value) : whatsappKeyId(value))) &&
        getAfter(uniqueKeyPath(type == 'email' ? emailKeyId(value) : whatsappKeyId(value))).data.userId == userId &&
        getAfter(uniqueKeyPath(type == 'email' ? emailKeyId(value) : whatsappKeyId(value))).data.type == type &&
        getAfter(uniqueKeyPath(type == 'email' ? emailKeyId(value) : whatsappKeyId(value))).data.value == value
      );
    }

    function isChangingField(field) {
      return !(field in resource.data) || !(field in request.resource.data) || resource.data[field] != request.resource.data[field];
    }

    function submissionDocPath(submissionId) {
      return /databases/$(database)/documents/submissions/$(submissionId);
    }

    function canAccessSubmissionById(submissionId) {
      return signedIn()
        && exists(submissionDocPath(submissionId))
        && (
          canMonitorAll() ||
          get(submissionDocPath(submissionId)).data.uploadedBy == myEmail() ||
          get(submissionDocPath(submissionId)).data.assignedTo == myEmail() ||
          get(submissionDocPath(submissionId)).data.reviewedBy == myEmail() ||
          get(submissionDocPath(submissionId)).data.assignedToRSA == myEmail() ||
          get(submissionDocPath(submissionId)).data.assignedToPayment == myEmail()
        );
    }

    function chatDocPath(chatId) {
      return /databases/$(database)/documents/applicationChats/$(chatId);
    }

    function chatDataHasParticipant(data) {
      return (data.participants is list) && (myEmail() in data.participants);
    }

    function canAccessChatByParticipants(chatId) {
      return signedIn()
        && exists(chatDocPath(chatId))
        && chatDataHasParticipant(get(chatDocPath(chatId)).data);
    }

    function canReadSubmission() {
      return signedIn() && (
        canMonitorAll() ||
        resource.data.uploadedBy == myEmail() ||
        resource.data.assignedTo == myEmail() ||
        resource.data.reviewedBy == myEmail() ||
        resource.data.assignedToRSA == myEmail() ||
        resource.data.assignedToPayment == myEmail() ||
        (
          resource.data.agentId is string &&
          resource.data.status == 'paid' &&
          exists(/databases/$(database)/documents/agents/$(resource.data.agentId)) &&
          (
            get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.createdByUid == request.auth.uid ||
            get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.createdBy == myEmail()
          )
        )
      );
    }

    function submissionAllowsUploaderMutation(data) {
      return data.uploadedBy != myEmail() ||
        !('auditFrozen' in data) ||
        data.auditFrozen != true;
    }

    function submissionAllowsUploaderMutationById(submissionId) {
      return !exists(submissionDocPath(submissionId)) ||
        get(submissionDocPath(submissionId)).data.uploadedBy != myEmail() ||
        !('auditFrozen' in get(submissionDocPath(submissionId)).data) ||
        get(submissionDocPath(submissionId)).data.auditFrozen != true;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwnUserDoc(userId)
        && globalWriteAllowed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == myEmail()
        && request.resource.data.role in ['uploader', 'admin', 'super_admin', 'reviewer', 'rsa', 'payment', 'reports_monitoring']
        && request.resource.data.status in ['pending', 'active', 'deactivated']
        && hasMatchingUniqueKeyAfter('email', request.resource.data.email, userId)
        && hasMatchingUniqueKeyAfter('whatsapp', request.resource.data.whatsappNumber, userId);
      allow update: if globalWriteAllowed()
        && (isOwnUserDoc(userId) || isAdminLike())
        && (!isChangingField('email') || hasMatchingUniqueKeyAfter('email', request.resource.data.email, userId))
        && (!isChangingField('whatsappNumber') || hasMatchingUniqueKeyAfter('whatsapp', request.resource.data.whatsappNumber, userId));
      allow delete: if globalWriteAllowed() && isAdminLike();
    }

    match /userUniqueKeys/{keyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && globalWriteAllowed()
        && request.resource.data.type in ['email', 'whatsapp']
        && request.resource.data.value is string
        && request.resource.data.value.size() > 0
        && request.resource.data.userId is string
        && (
          request.resource.data.userId == request.auth.uid ||
          isAdminLike()
        );
      allow update: if signedIn()
        && globalWriteAllowed()
        && request.resource.data.type in ['email', 'whatsapp']
        && request.resource.data.value is string
        && request.resource.data.value.size() > 0
        && request.resource.data.userId is string
        && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          isAdminLike()
        );
      allow delete: if signedIn() && globalWriteAllowed() && (
        resource.data.userId == request.auth.uid ||
        isAdminLike()
      );
    }

    match /submissionUniqueKeys/{keyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && globalWriteAllowed()
        && request.resource.data.type in ['account_number', 'nin', 'pen', 'phone', 'customer_name']
        && request.resource.data.value is string
        && request.resource.data.value.size() > 0
        && request.resource.data.submissionId is string
        && request.resource.data.uploadedBy == myEmail()
        && existsAfter(submissionDocPath(request.resource.data.submissionId))
        && getAfter(submissionDocPath(request.resource.data.submissionId)).data.uploadedBy == myEmail();
      allow update: if signedIn()
        && globalWriteAllowed()
        && request.resource.data.type in ['account_number', 'nin', 'pen', 'phone', 'customer_name']
        && request.resource.data.value is string
        && request.resource.data.value.size() > 0
        && request.resource.data.submissionId is string
        && request.resource.data.uploadedBy == myEmail()
        && existsAfter(submissionDocPath(request.resource.data.submissionId))
        && getAfter(submissionDocPath(request.resource.data.submissionId)).data.uploadedBy == myEmail()
        && (
          resource.data.submissionId == request.resource.data.submissionId ||
          isAdminLike()
        );
      allow delete: if signedIn() && globalWriteAllowed() && isAdminLike();
    }

    match /submissions/{submissionId} {
      allow read: if canReadSubmission();
      allow create: if signedIn()
        && globalWriteAllowed()
        && isAnyRole(['uploader', 'admin', 'super_admin'])
        && request.resource.data.uploadedBy == myEmail();
      allow update: if signedIn() && globalWriteAllowed() && (
        isAdminLike() ||
        isRole('reports_monitoring') ||
        (
          submissionAllowsUploaderMutation(resource.data) &&
          (
            resource.data.uploadedBy == myEmail() ||
            resource.data.assignedTo == myEmail() ||
            resource.data.assignedToRSA == myEmail() ||
            resource.data.assignedToPayment == myEmail()
          )
        )
      );
      allow delete: if globalWriteAllowed() && isAdminLike();
    }

    match /uploaderRoutingRules/{docId} {
      allow read: if signedIn();
      allow write: if globalWriteAllowed() && isAdminLike();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAnyRole(['super_admin']);
    }

    match /audit/{docId} {
      allow read: if canMonitorAll();
      allow create: if signedIn() && globalWriteAllowed() && isAnyRole(['admin', 'super_admin', 'reports_monitoring', 'uploader', 'payment', 'rsa', 'reviewer']);
      allow update, delete: if false;
    }

    match /counters/{docId} {
      allow read: if signedIn();
      allow write: if globalWriteAllowed() && isAnyRole(['admin', 'super_admin', 'uploader', 'reviewer', 'rsa']);
    }

    match /roundRobinAssignments/{docId} {
      allow read: if signedIn();
      allow write: if globalWriteAllowed() && isAnyRole(['admin', 'super_admin', 'uploader']);
    }

    match /roundRobinAssignmentsRSA/{docId} {
      allow read: if signedIn();
      allow write: if globalWriteAllowed() && isAnyRole(['admin', 'super_admin', 'reviewer']);
    }

    match /roundRobinAssignmentsPayment/{docId} {
      allow read: if signedIn();
      allow write: if globalWriteAllowed() && isAnyRole(['admin', 'super_admin', 'rsa']);
    }

    match /emailNotificationEvents/{docId} {
      allow read: if isAdminLike();
      allow create, update: if signedIn() && globalWriteAllowed();
      allow delete: if false;
    }

    match /agents/{agentId} {
      allow read: if signedIn() && (
        resource.data.status == 'approved' ||
        isAdminLike()
      );
      allow create: if signedIn()
        && globalWriteAllowed()
        && isAnyRole(['uploader', 'admin', 'super_admin'])
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == myEmail();
      allow update: if globalWriteAllowed() && isAdminLike();
      allow delete: if globalWriteAllowed() && isAdminLike();
    }

    match /applicationChats/{chatId} {
      allow read: if signedIn() && (
        chatDataHasParticipant(resource.data) ||
        (resource.data.submissionId is string && canAccessSubmissionById(resource.data.submissionId)) ||
        canAccessSubmissionById(chatId)
      );
      allow create: if signedIn() && (
        globalWriteAllowed()
        && submissionAllowsUploaderMutationById(
          request.resource.data.submissionId is string
            ? request.resource.data.submissionId
            : chatId
        )
        && (
          chatDataHasParticipant(request.resource.data) ||
          (request.resource.data.submissionId is string && canAccessSubmissionById(request.resource.data.submissionId)) ||
          canAccessSubmissionById(chatId)
        )
      );
      allow update: if signedIn() && globalWriteAllowed() && (
        submissionAllowsUploaderMutationById(
          resource.data.submissionId is string
            ? resource.data.submissionId
            : chatId
        )
        && (
          chatDataHasParticipant(resource.data) ||
          chatDataHasParticipant(request.resource.data) ||
          (resource.data.submissionId is string && canAccessSubmissionById(resource.data.submissionId)) ||
          canAccessSubmissionById(chatId)
        )
      );
      allow delete: if maintenanceWriteAllowed() && isAdminLike();

      match /messages/{messageId} {
        allow read: if signedIn() && (
          canAccessSubmissionById(chatId) ||
          canAccessChatByParticipants(chatId)
        );
        allow create: if signedIn()
          && globalWriteAllowed()
          && submissionAllowsUploaderMutationById(chatId)
          && (
            canAccessSubmissionById(chatId) ||
            canAccessChatByParticipants(chatId)
          )
          && request.resource.data.senderEmail == myEmail()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
